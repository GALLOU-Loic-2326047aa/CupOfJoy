<section class="main-banner">
    <a class="banner-link" href="{$banner_link}" title="{$banner_desc}">
        {if isset($banner_img)}
            <img src="{$banner_img}" alt="{$banner_desc}" title="{$banner_desc}" class="img-fluid banner-bg">
        {/if}

        <div class="banner-overlay">
            <div class="banner-content">
                <h1 class="h1 banner-title">L'Expérience Premium</h1>
                <p class="banner-subtitle">Découvrez notre nouvelle sélection exclusive.</p>
                <span class="btn-action">Découvrir</span>
            </div>
        </div>
    </a>
</section>