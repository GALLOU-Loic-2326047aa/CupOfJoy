{
    "name": "prestashop/bantgorgias",
    "description": "Gorgias integration for PrestaShop",
    "config": {
        "platform": {
            "php": "8.1"
        },
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true,
        "prepend-autoloader": false
    },
    "require": {
        "php": ">=8.1",
        "prestashop/module-lib-mbo-installer": "^3.0",
        "prestashop/module-lib-service-container": "^2.0",
        "prestashop/prestashop-accounts-installer": "^1.0",
        "ext-curl": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.85",
        "phpstan/phpstan": "^2.1",
        "prestashop/autoindex": "^2.1",
        "prestashop/header-stamp": "^2.6",
        "prestashop/php-dev-tools": "^5.0",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "autoload": {
        "psr-4": {
            "Bant\\BantGorgias\\": "src/"
        },
        "classmap": [
            "bantgorgias.php",
            "controllers"
        ]
    },
    "author": "PrestaShop",
    "license": "MIT"
}
